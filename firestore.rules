rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: apps
    // Document ID: appId
    // Fields:
    //   - name: string (required)
    //   - ownerId: string (required) - UID of the owner
    //   - createdAt: timestamp (required)
    //   - platform: string (required, enum: iOS, Android, Web)
    //   - status: string (required, enum: Draft, Published)
    //   - version: string (optional)
    //
    // Collection: apps/{appId}/screens
    // Document ID: screenId
    // Fields:
    //   - appId: string (required)
    //   - imageUrl: string (required)
    //   - order: number (required)
    //   - name: string (required)
    //
    // Collection: apps/{appId}/screens/{screenId}/hotspots
    // Document ID: hotspotId
    // Fields:
    //   - screenId: string (required)
    //   - targetScreenId: string (required)
    //   - x: number (required)
    //   - y: number (required)
    //   - width: number (required)
    //   - height: number (required)
    //   - label: string (optional)
    //
    // Collection: apps/{appId}/issues
    // Document ID: issueId
    // Fields:
    //   - appId: string (required)
    //   - screenId: string (required)
    //   - authorId: string (required)
    //   - authorName: string (required)
    //   - text: string (required)
    //   - x: number (required)
    //   - y: number (required)
    //   - createdAt: timestamp (required)
    //   - priority: string (required, enum: Low, Medium, High)
    //   - status: string (required, enum: Open, Resolved)
    //
    // Collection: apps/{appId}/guestSuggestions
    // Document ID: suggestionId
    // Fields:
    //   - appId: string (required)
    //   - screenId: string (required)
    //   - guestId: string (required) - UUID gerado no frontend
    //   - guestName: string (required) - nome informado pelo convidado
    //   - text: string (required)
    //   - x: number (required)
    //   - y: number (required)
    //   - createdAt: timestamp (required)
    //   - priority: string (required, enum: Low, Medium, High)
    //   - status: string (required, enum: Open, Resolved)
    //   - source: string (required, value: "guest")
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAppOwner(appId) {
      return isAuthenticated() && get(/databases/$(database)/documents/apps/$(appId)).data.ownerId == request.auth.uid;
    }

    function isValidApp(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerId is string && data.ownerId == request.auth.uid &&
             data.platform in ['iOS', 'Android', 'Web'] &&
             data.status in ['Draft', 'Published'];
    }

    function isValidScreen(data) {
      return data.appId is string &&
             data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() < 900000 &&
             data.order is number && data.order >= 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             ((data.device is string && data.device in ['mobile', 'desktop']) ||
              (data.deviceType is string && data.deviceType in ['Mobile', 'Desktop']));
    }

    function isValidHotspot(data) {
      return data.screenId is string &&
             data.targetScreenId is string &&
             data.x is number && data.x >= 0 && data.x <= 100 &&
             data.y is number && data.y >= 0 && data.y <= 100 &&
             data.width is number && data.width > 0 && data.width <= 100 &&
             data.height is number && data.height > 0 && data.height <= 100;
    }

    function isValidIssue(data) {
      return data.appId is string &&
             data.screenId is string &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
             data.x is number && data.y is number &&
             data.priority in ['Low', 'Medium', 'High'] &&
             data.status in ['Open', 'Resolved'];
    }

    function isValidGuestSuggestion(data) {
      return data.keys().hasAll(['appId', 'screenId', 'guestId', 'guestName', 'text',
                                  'x', 'y', 'createdAt', 'priority', 'status', 'source']) &&
             data.guestId is string && data.guestId.size() >= 10 && data.guestId.size() <= 64 &&
             data.guestName is string && data.guestName.size() > 0 && data.guestName.size() <= 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.x is number && data.x >= 0 && data.x <= 100 &&
             data.y is number && data.y >= 0 && data.y <= 100 &&
             data.priority in ['Low', 'Medium', 'High'] &&
             data.status == 'Open' &&
             data.source == 'guest';
    }

    function isValidNpsResponse(data, appDocId) {
      return data.keys().hasAll(['appId', 'userName', 'score', 'classification', 'issueIds', 'createdAt']) &&
             data.appId is string && data.appId == appDocId &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() <= 100 &&
             data.score is number && data.score >= 0 && data.score <= 10 &&
             data.classification in ['detractor', 'neutral', 'promoter'] &&
             data.issueIds is list && data.issueIds.size() <= 100;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "leonardorsolar@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /apps/{appId} {
      // Apps Published podem ser lidos sem autenticação (link de feedback compartilhado)
      allow read: if isAuthenticated() || resource.data.status == 'Published';
      allow create: if isAuthenticated() && isValidApp(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidApp(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId);

      match /screens/{screenId} {
        // Telas são imagens de protótipo – leitura pública para o viewer de feedback
        allow read: if true;
        allow create: if isAppOwner(appId) && isValidScreen(request.resource.data);
        allow update: if isAppOwner(appId) && isValidScreen(request.resource.data);
        allow delete: if isAppOwner(appId);

        match /hotspots/{hotspotId} {
          // Hotspots são navegação de protótipo – leitura pública para o viewer de feedback
          allow read: if true;
          allow create: if isAppOwner(appId) && isValidHotspot(request.resource.data);
          allow update: if isAppOwner(appId) && isValidHotspot(request.resource.data);
          allow delete: if isAppOwner(appId);
        }
      }

      match /issues/{issueId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidIssue(request.resource.data);
        allow update: if (isOwner(resource.data.authorId) || isAppOwner(appId)) && isValidIssue(request.resource.data);
        allow delete: if isOwner(resource.data.authorId) || isAppOwner(appId);
      }

      match /guestSuggestions/{suggestionId} {
        // Convidados não autenticados podem criar sugestões (validação rigorosa no server-side)
        allow create: if isValidGuestSuggestion(request.resource.data) &&
                         request.resource.data.appId == appId;
        // Apenas o dono do app autenticado pode ler, atualizar status e deletar
        allow read:   if isAuthenticated() && isAppOwner(appId);
        allow update: if isAuthenticated() && isAppOwner(appId);
        allow delete: if isAuthenticated() && isAppOwner(appId);
      }

      match /npsResponses/{npsId} {
        // Convidados (sem auth) enviam NPS ao finalizar o fluxo de feedback
        allow create: if isValidNpsResponse(request.resource.data, appId);
        // Igual a guestSuggestions: só o dono do app lê (evita vazar NPS para qualquer usuário logado)
        allow read: if isAuthenticated() && isAppOwner(appId);
        allow update, delete: if false;
      }
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }
  }
}
